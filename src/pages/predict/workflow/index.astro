---
import Layout from "../_layout.astro";
import WorkflowForm from "./_blocks/WorkflowForm.vue";
---

<Layout active="./workflow">
    <div class="page-header">
        <h1>智能流程</h1>
        <p class="subtitle">图像识别 → 掩码生成 → 图像增强 一站式处理</p>
    </div>
    <WorkflowForm client:load />
</Layout>

<style>
    .page-header {
        margin-bottom: 16px;
    }
    .page-header h1 {
        margin: 0 0 8px 0;
        font-size: 24px;
        font-weight: 600;
    }
    .subtitle {
        margin: 0;
        color: var(--el-text-color-secondary);
        font-size: 14px;
    }
</style>
