---
import ParentLayout from "../_layout.astro";

const asideNav = [
    { href: "./image", text: "图像识别" },
    { href: "./video", text: "视频识别" },
    { href: "./mask", text: "掩码生成" },
    { href: "./enhance", text: "图像增强" }
] as const;

export interface Props {
    active?: (typeof asideNav)[number]["href"];
}

const { active } = Astro.props as Props;
---

<ParentLayout headerActive="/predict" asideNav={asideNav} asideActive={active}>
    <slot />
</ParentLayout>
